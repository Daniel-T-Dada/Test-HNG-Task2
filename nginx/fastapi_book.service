[Unit]
Description=FastAPI Book Management API
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/path/to/fastapi-book-project
Environment="PATH=/path/to/fastapi-book-project/venv/bin"
ExecStart=/path/to/fastapi-book-project/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000 --workers 4
Restart=always

[Install]
WantedBy=multi-user.target 